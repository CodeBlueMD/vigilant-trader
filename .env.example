# VigilantTrader — Positional Edition
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Watchlist ──────────────────────────────────────────────────────────────
# Tickers you already hold (alerts framed as "monitor/add/trim")
HOLDING_TICKERS=IBIT,QQQM,GLD

# Tickers you are watching for fresh entry opportunities
WATCHLIST_TICKERS=VFV.TO,AAPL,TSLA,SPY,NVDA,TSM,CRWD,NFLX,AMZN,GOOGL

# ── Portfolio context ──────────────────────────────────────────────────────
AVAILABLE_CAPITAL_USD=0

# JSON string — each holding: shares/oz, book_value_usd or book_value_cad
# Example:
# PORTFOLIO_HOLDINGS_JSON={"IBIT":{"shares":20,"book_value_usd":1060.60},"QQQM":{"shares":18,"book_value_usd":4517.92},"GLD":{"oz":0.529,"book_value_cad":3500.0,"currency":"CAD"}}
PORTFOLIO_HOLDINGS_JSON={}

# ── Email (Gmail SMTP) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_RECIPIENT=your_gmail@gmail.com

# ── AI Backends (all free) ─────────────────────────────────────────────────
# Groq free tier — get key at console.groq.com
GROQ_API_KEY=

# Model order: compound-beta first (web search), falls back to llama-3.3-70b
GROQ_MODEL_PRIMARY=compound-beta
GROQ_MODEL_FALLBACK=llama-3.3-70b-versatile

# Local Ollama (optional fallback) — install from ollama.com
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Primary backend: groq | ollama
AI_BACKEND=groq

# ── Schedule ───────────────────────────────────────────────────────────────
TIMEZONE=America/Toronto
ANALYSIS_HOUR=16
ANALYSIS_MINUTE=15

# ── Storage ────────────────────────────────────────────────────────────────
DB_PATH=vigilant.db
LOG_FILE=vigilant.log
